# Sensitive output — never commit these
findings/
recon/
reports/
hunt-memory/
config.json
*.burp
*.json.bak

# Stored session credentials (real tokens — never commit)
memory/sessions.json

# API keys and tokens
.env
secrets.txt
api_keys.txt

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/

# macOS
.DS_Store
.AppleDouble

# Logs
*.log
*.txt.bak

# Tool output
*.out
nmap-output/

# Dead-branch memory (per-machine)
memory/hunt_state.json
memory/.hunt_state.lock
